// ─────────────────────────────────────────────
//  DINO RUNNER — game.js
//  Tất cả logic game nằm ở đây.
// ─────────────────────────────────────────────

const canvas  = document.getElementById('c');
const ctx     = canvas.getContext('2d');
const scoreEl = document.getElementById('score');
const hiEl    = document.getElementById('hiScore');
const puEl    = document.getElementById('powerups');
const overlay = document.getElementById('overlay');
const tauntEl = document.getElementById('taunt');
const mileEl  = document.getElementById('milestones');
const startBtn = document.getElementById('startBtn');

// ── Constants ──────────────────────────────────
const W      = 800;
const H      = 320;
const GROUND = 240;

canvas.width  = W;
canvas.height = H;

// ── Hi-score (persisted) ───────────────────────
let hiScore = Number(localStorage.getItem('dinoHi') || 0);
hiEl.textContent = 'HI ' + fmt(hiScore);

// ── Taunt pool ─────────────────────────────────
const TAUNTS = [
  'địt mẹ mày đồ ngu',
  'ahaha',
  'ngu vcl',
  'dậy múa đi, sao không múa nữa',
  'phải gì ạ? phải gì ạ? phải gìiii? phải chịuuuuu !!!!!',
];
let lastTauntIdx = -1;
function getTaunt() {
  let idx;
  do { idx = Math.floor(Math.random() * TAUNTS.length); } while (idx === lastTauntIdx);
  lastTauntIdx = idx;
  return TAUNTS[idx];
}

// ── Helpers ────────────────────────────────────
function fmt(n) { return String(Math.floor(n)).padStart(5, '0'); }

function rectsOverlap(a, b) {
  // a,b: { x, y (bottom), w, h }
  return a.x < b.x + b.w &&
         a.x + a.w > b.x &&
         a.y - a.h < b.y &&
         a.y > b.y - b.h;
}

function dinoHitbox(d) {
  return { x: d.x + 8, y: d.y, w: d.w - 14, h: d.h - 4 };
}

function explosion(x, y, color = '#ff6600') {
  for (let i = 0; i < 14; i++) {
    const ang = Math.random() * Math.PI * 2;
    const spd = Math.random() * 4 + 2;
    game.particles.push({
      x, y,
      vx: Math.cos(ang) * spd,
      vy: Math.sin(ang) * spd - 1,
      r: Math.random() * 5 + 2,
      life: 30, maxLife: 30,
      color,
    });
  }
}

let mileTimeout = null;
function showMile(msg) {
  mileEl.textContent = msg;
  mileEl.style.opacity = '1';
  clearTimeout(mileTimeout);
  mileTimeout = setTimeout(() => { mileEl.style.opacity = '0'; }, 2200);
}

// ── Game state ─────────────────────────────────
let game = {};
let animId = null;

function initGame() {
  game = {
    running:   false,
    score:     0,
    speed:     6,
    baseSpeed: 6,
    frame:     0,

    // ground animation offset
    groundX: 0,

    // dino
    dino: {
      x: 80, y: GROUND,
      w: 44,  h: 48,
      vy: 0,
      jumping: false,
      jumpCount: 0,
      legFrame: 0,
      // powerup states (in frames @ 60fps)
      invincible: 0,
      shield: 0,
      slowEffect: 0,
      // weapon
      gun: false,
      gunCooldown: 0,
    },

    // companions / escorts
    companion: null,   // pterodactyl friend (unlocked at 100)
    ufo: null,         // UFO escort (unlocked at 250)
    ufoCooldown: 0,

    // world objects
    obstacles:    [],  // cacti
    pterodactyls: [],  // enemy flyers
    barrels:      [],  // slow barrels (500+)
    slimes:       [],  // speed-reducing slimes (600+)

    // projectiles & fx
    bullets:   [],
    particles: [],
    clouds:    [{ x: 200, y: 50 }, { x: 500, y: 80 }, { x: 710, y: 35 }],
    stars:     Array.from({ length: 22 }, () => ({
      x: Math.random() * W,
      y: Math.random() * 100,
      s: Math.random() * 1.5 + 0.5,
    })),

    // spawn timers
    obstacleTimer: 80,
    pterTimer:     200,
    barrelTimer:   300,
    slimeTimer:    260,

    // milestone tracking
    milestoneReached:   0,
    lastSpeedMilestone: 0,

    // powerup drop timer
    powerupTimer: 900,

    // night mode
    nightMode:  false,
    nightTimer: 700,
  };
}

// ── Spawn helpers ──────────────────────────────
function spawnCactus() {
  const variants = [
    { w: 20, h: 40, count: 1 },
    { w: 30, h: 52, count: 2 },
    { w: 16, h: 34, count: 1 },
    { w: 44, h: 60, count: 2 },
  ];
  const v = variants[Math.floor(Math.random() * variants.length)];
  game.obstacles.push({ x: W + 10, y: GROUND, w: v.w, h: v.h, count: v.count, type: 'cactus' });
}

function spawnBarrel() {
  game.barrels.push({ x: W + 20, y: GROUND, w: 32, h: 32, type: 'barrel' });
}

function spawnPter() {
  const ys = [GROUND - 30, GROUND - 60, GROUND - 90];
  game.pterodactyls.push({
    x: W + 20,
    y: ys[Math.floor(Math.random() * ys.length)],
    w: 46, h: 28,
    frame: 0,
    type: 'pter',
  });
}

function spawnSlime() {
  game.slimes.push({ x: W + 20, y: GROUND, w: 36, h: 30, frame: 0, type: 'slime' });
}

// ── Draw functions ─────────────────────────────

function drawDino(d) {
  ctx.save();

  // blink when invincible
  if (d.invincible > 0 && Math.floor(d.invincible / 4) % 2 === 1) {
    ctx.restore(); return;
  }

  // shield ring
  if (d.shield > 0) {
    ctx.beginPath();
    ctx.arc(d.x + d.w / 2, d.y - d.h / 2, 34, 0, Math.PI * 2);
    ctx.strokeStyle = 'rgba(100,180,255,0.65)';
    ctx.lineWidth = 3;
    ctx.stroke();
  }

  ctx.fillStyle = '#535353';

  // body
  ctx.beginPath();
  ctx.roundRect(d.x + 4, d.y - d.h + 10, d.w - 8, d.h - 18, 6);
  ctx.fill();

  // neck + head
  ctx.beginPath();
  ctx.roundRect(d.x + d.w - 14, d.y - d.h + 2, 20, 20, 4);
  ctx.fill();

  // eye
  ctx.fillStyle = '#f7f7f0';
  ctx.fillRect(d.x + d.w + 1, d.y - d.h + 5, 6, 6);
  ctx.fillStyle = '#222';
  ctx.fillRect(d.x + d.w + 2, d.y - d.h + 6, 4, 4);

  // mouth
  ctx.fillStyle = '#535353';
  ctx.fillRect(d.x + d.w + 6, d.y - d.h + 18, 6, 2);

  // tail
  ctx.beginPath();
  ctx.moveTo(d.x + 6,  d.y - 16);
  ctx.lineTo(d.x - 10, d.y - 8);
  ctx.lineTo(d.x + 4,  d.y - 6);
  ctx.fill();

  // legs
  ctx.fillStyle = '#535353';
  if (!d.jumping) {
    const swing = Math.sin(d.legFrame * 0.28) * 7;
    ctx.fillRect(d.x + 10, d.y - 12, 10, 14 + swing);
    ctx.fillRect(d.x + 22, d.y - 12, 10, 14 - swing);
  } else {
    ctx.fillRect(d.x + 10, d.y - 12, 10, 12);
    ctx.fillRect(d.x + 22, d.y - 6,  10, 8);
  }

  // gun on back
  if (d.gun) {
    ctx.fillStyle = '#222';
    ctx.fillRect(d.x + d.w - 4, d.y - d.h + 24, 20, 8);
    ctx.fillRect(d.x + d.w + 12, d.y - d.h + 22, 4, 12);
  }

  ctx.restore();
}

function drawPterodactyl(p, color = '#535353') {
  const flap = Math.sin(p.frame * 0.25) > 0;
  ctx.save();
  ctx.fillStyle = color;

  // body
  ctx.beginPath();
  ctx.ellipse(p.x + 23, p.y + 14, 14, 8, 0, 0, Math.PI * 2);
  ctx.fill();

  // beak
  ctx.beginPath();
  ctx.moveTo(p.x + 34, p.y + 10);
  ctx.lineTo(p.x + 52, p.y + 8);
  ctx.lineTo(p.x + 34, p.y + 16);
  ctx.fill();

  // wings
  if (flap) {
    ctx.beginPath(); ctx.moveTo(p.x+20,p.y+10); ctx.lineTo(p.x,p.y-6);    ctx.lineTo(p.x+12,p.y+13); ctx.fill();
    ctx.beginPath(); ctx.moveTo(p.x+26,p.y+10); ctx.lineTo(p.x+48,p.y-4); ctx.lineTo(p.x+36,p.y+13); ctx.fill();
  } else {
    ctx.beginPath(); ctx.moveTo(p.x+20,p.y+12); ctx.lineTo(p.x+2,p.y+24);  ctx.lineTo(p.x+12,p.y+14); ctx.fill();
    ctx.beginPath(); ctx.moveTo(p.x+26,p.y+12); ctx.lineTo(p.x+44,p.y+22); ctx.lineTo(p.x+34,p.y+14); ctx.fill();
  }

  ctx.restore();
}

function drawCactus(o) {
  ctx.save();
  ctx.fillStyle = '#535353';
  const cx = o.x, cy = o.y - o.h, cw = o.w, ch = o.h;
  // main trunk
  ctx.fillRect(cx + cw/2 - 5, cy, 10, ch);
  if (o.count >= 1) {
    ctx.fillRect(cx, cy + ch*0.3, cw/2 - 4, 8);
    ctx.fillRect(cx, cy + ch*0.08, 8, ch*0.32);
  }
  if (o.count >= 2) {
    ctx.fillRect(cx + cw/2 + 4, cy + ch*0.4, cw/2 - 4, 8);
    ctx.fillRect(cx + cw - 8, cy + ch*0.18, 8, ch*0.32);
  }
  ctx.restore();
}

function drawBarrel(b) {
  ctx.save();
  ctx.fillStyle = '#8B4513';
  ctx.beginPath();
  ctx.roundRect(b.x, b.y - b.h, b.w, b.h, 5);
  ctx.fill();
  ctx.strokeStyle = '#5a2d0c';
  ctx.lineWidth = 2;
  ctx.beginPath(); ctx.moveTo(b.x+4, b.y-b.h+8);  ctx.lineTo(b.x+b.w-4, b.y-b.h+8);  ctx.stroke();
  ctx.beginPath(); ctx.moveTo(b.x+4, b.y-8);       ctx.lineTo(b.x+b.w-4, b.y-8);       ctx.stroke();
  ctx.restore();
}

function drawSlime(s) {
  ctx.save();
  ctx.fillStyle = '#3cb371';
  ctx.beginPath();
  ctx.ellipse(s.x + s.w/2, s.y - s.h/2, s.w/2, s.h/2, 0, 0, Math.PI * 2);
  ctx.fill();
  // sheen
  ctx.fillStyle = 'rgba(255,255,255,0.4)';
  ctx.beginPath();
  ctx.ellipse(s.x + s.w/2 - 6, s.y - s.h/2 - 5, 5, 3, -0.4, 0, Math.PI * 2);
  ctx.fill();
  // eyes
  ctx.fillStyle = '#111';
  ctx.fillRect(s.x + s.w/2 - 9, s.y - s.h/2 - 2, 4, 4);
  ctx.fillRect(s.x + s.w/2 + 4,  s.y - s.h/2 - 2, 4, 4);
  ctx.restore();
}

function drawUFO(u) {
  ctx.save();
  const blink = Math.floor(game.frame / 8) % 2 === 0;

  // saucer body
  ctx.fillStyle = '#999';
  ctx.beginPath();
  ctx.ellipse(u.x, u.y, 32, 11, 0, 0, Math.PI * 2);
  ctx.fill();

  // dome
  ctx.fillStyle = '#bbb';
  ctx.beginPath();
  ctx.ellipse(u.x, u.y - 7, 18, 12, 0, 0, Math.PI * 2);
  ctx.fill();

  // blinking lights
  const lights = ['#f00', '#0f0', '#00f', '#ff0'];
  for (let i = 0; i < 4; i++) {
    ctx.fillStyle = blink ? lights[i] : '#444';
    ctx.beginPath();
    ctx.arc(u.x - 18 + i * 12, u.y + 7, 3, 0, Math.PI * 2);
    ctx.fill();
  }

  // cooldown ring
  if (game.ufoCooldown > 0) {
    ctx.strokeStyle = 'rgba(255,150,0,0.45)';
    ctx.lineWidth = 3;
    ctx.beginPath();
    ctx.arc(u.x, u.y, 36, -Math.PI/2, -Math.PI/2 + (game.ufoCooldown / 120) * Math.PI * 2);
    ctx.stroke();
  }

  ctx.restore();
}

function drawCompanion(c) {
  // purple friend pterodactyl
  drawPterodactyl({ x: c.x, y: c.y, frame: game.frame }, '#7B68EE');
}

function drawBullet(b) {
  ctx.save();
  ctx.fillStyle = b.fromGun ? '#ff4400' : '#ffaa00';
  ctx.beginPath();
  ctx.arc(b.x, b.y, 5, 0, Math.PI * 2);
  ctx.fill();
  // trail
  ctx.fillStyle = b.fromGun ? 'rgba(255,68,0,0.3)' : 'rgba(255,170,0,0.3)';
  ctx.beginPath();
  ctx.arc(b.x - b.vx * 2, b.y - b.vy * 2, 4, 0, Math.PI * 2);
  ctx.fill();
  ctx.restore();
}

function drawParticle(p) {
  ctx.save();
  ctx.globalAlpha = p.life / p.maxLife;
  ctx.fillStyle = p.color;
  ctx.beginPath();
  ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
  ctx.fill();
  ctx.restore();
}

function drawGround() {
  ctx.strokeStyle = '#535353';
  ctx.lineWidth = 2;
  ctx.beginPath(); ctx.moveTo(0, GROUND + 2); ctx.lineTo(W, GROUND + 2); ctx.stroke();

  // ground texture lines
  ctx.lineWidth = 1;
  ctx.strokeStyle = game.nightMode ? '#444' : '#ccc';
  for (let i = 0; i < 6; i++) {
    const x = (game.groundX + i * (W / 4)) % W;
    ctx.beginPath(); ctx.moveTo(x, GROUND + 5); ctx.lineTo(x + 18, GROUND + 5); ctx.stroke();
  }
}

function drawClouds() {
  ctx.fillStyle = game.nightMode ? 'rgba(180,180,210,0.35)' : 'rgba(210,210,210,0.55)';
  game.clouds.forEach(c => {
    ctx.beginPath(); ctx.ellipse(c.x,     c.y,    30, 12, 0, 0, Math.PI*2); ctx.fill();
    ctx.beginPath(); ctx.ellipse(c.x+20,  c.y-7,  20, 10, 0, 0, Math.PI*2); ctx.fill();
    ctx.beginPath(); ctx.ellipse(c.x-16,  c.y-5,  18,  9, 0, 0, Math.PI*2); ctx.fill();
  });
}

function drawStars() {
  if (!game.nightMode) return;
  ctx.fillStyle = '#fff';
  game.stars.forEach(s => {
    ctx.globalAlpha = 0.6 + Math.sin(game.frame * 0.03 + s.x) * 0.2;
    ctx.beginPath(); ctx.arc(s.x, s.y, s.s, 0, Math.PI * 2); ctx.fill();
  });
  ctx.globalAlpha = 1;
}

// ── Update ─────────────────────────────────────

function update() {
  const g = game;
  const d = g.dino;
  g.frame++;

  // ── Score & speed ──────────────────────────
  g.score += 0.1;
  scoreEl.textContent = fmt(g.score);
  if (g.score > hiScore) {
    hiScore = g.score;
    localStorage.setItem('dinoHi', Math.floor(hiScore));
    hiEl.textContent = 'HI ' + fmt(hiScore);
  }

  const sMilestone = Math.floor(g.score / 100);
  if (sMilestone > g.lastSpeedMilestone) {
    g.speed = g.baseSpeed + sMilestone * 0.5;
    g.lastSpeedMilestone = sMilestone;
    if (sMilestone > 0) showMile('Tốc độ tăng! ×' + g.speed.toFixed(1));
  }

  const spd = d.slowEffect > 0 ? g.speed * 0.8 : g.speed;

  // ── Milestones ─────────────────────────────
  const sc = Math.floor(g.score);
  if (sc >= 100  && g.milestoneReached < 100)  { g.milestoneReached = 100;  g.companion = { x: d.x - 70, y: d.y - 85 }; showMile('Thằn lằn bay đồng hành xuất hiện!'); }
  if (sc >= 250  && g.milestoneReached < 250)  { g.milestoneReached = 250;  g.ufo = { x: d.x + 140, y: d.y - 100 };     showMile('UFO bảo vệ xuất hiện!'); }
  if (sc >= 1000 && g.milestoneReached < 1000) { g.milestoneReached = 1000; d.gun = true;                                showMile('Súng được trang bị! Nhấn Z để bắn'); }

  // ── Night mode toggle ──────────────────────
  g.nightTimer--;
  if (g.nightTimer <= 0) { g.nightMode = !g.nightMode; g.nightTimer = 700; }

  // ── Ground scroll ──────────────────────────
  g.groundX = (g.groundX - spd + W) % W;

  // ── Clouds ────────────────────────────────
  g.clouds.forEach(c => { c.x -= spd * 0.25; if (c.x < -80) { c.x = W + 80; c.y = 30 + Math.random() * 70; } });

  // ── Dino physics ──────────────────────────
  if (d.jumping) {
    d.vy += 0.72;
    d.y  += d.vy;
    if (d.y >= GROUND) { d.y = GROUND; d.vy = 0; d.jumping = false; d.jumpCount = 0; }
  }
  if (!d.jumping) d.legFrame++;
  if (d.invincible  > 0) d.invincible--;
  if (d.shield      > 0) d.shield--;
  if (d.slowEffect  > 0) d.slowEffect--;
  if (d.gunCooldown > 0) d.gunCooldown--;

  // ── Companion follows dino ─────────────────
  if (g.companion) {
    const tx = d.x - 70, ty = d.y - 85 + Math.sin(g.frame * 0.05) * 10;
    g.companion.x += (tx - g.companion.x) * 0.08;
    g.companion.y += (ty - g.companion.y) * 0.08;
  }

  // ── UFO follows dino ───────────────────────
  if (g.ufo) {
    const tx = d.x + 140, ty = d.y - 100 + Math.sin(g.frame * 0.04) * 14;
    g.ufo.x += (tx - g.ufo.x) * 0.06;
    g.ufo.y += (ty - g.ufo.y) * 0.06;
    if (g.ufoCooldown > 0) g.ufoCooldown--;
  }

  // ── Random powerup drop ────────────────────
  g.powerupTimer--;
  if (g.powerupTimer <= 0) {
    g.powerupTimer = 600 + Math.floor(Math.random() * 600);
    if (Math.random() < 0.5) { d.invincible = 300; showMile('★ Bất tử 5 giây!'); }
    else                     { d.shield = 300;     showMile('★ Khiên bảo vệ!'); }
  }

  // ── Spawn timers ───────────────────────────
  g.obstacleTimer--;
  if (g.obstacleTimer <= 0) {
    const gap = Math.max(40, 100 - Math.floor(g.score / 100) * 3);
    g.obstacleTimer = gap + Math.floor(Math.random() * 60);
    if (g.score >= 500 && Math.random() < 0.18) spawnBarrel();
    else spawnCactus();
  }

  g.pterTimer--;
  if (g.pterTimer <= 0 && g.score >= 100) {
    spawnPter();
    g.pterTimer = 130 + Math.floor(Math.random() * 110);
  }

  if (g.score >= 600) {
    g.slimeTimer--;
    if (g.slimeTimer <= 0) { spawnSlime(); g.slimeTimer = 180 + Math.floor(Math.random() * 130); }
  }

  // ── UFO auto-shoot ─────────────────────────
  if (g.ufo && g.ufoCooldown === 0) {
    const allTargets = [...g.obstacles, ...g.barrels, ...g.pterodactyls];
    const closest = allTargets
      .filter(o => o.x > d.x && o.x < g.ufo.x + 30)
      .sort((a, b) => a.x - b.x)[0];
    if (closest) {
      const ty = closest.y - (closest.h || 0) / 2;
      const dx = closest.x - g.ufo.x, dy = ty - g.ufo.y;
      const len = Math.sqrt(dx*dx + dy*dy) || 1;
      g.bullets.push({ x: g.ufo.x, y: g.ufo.y, vx: 7*(dx/len), vy: 7*(dy/len), target: closest, fromGun: false });
      g.ufoCooldown = 120; // 2 seconds @ 60fps
    }
  }

  // ── Companion auto-shoot ───────────────────
  if (g.companion) {
    g.pterodactyls.forEach(p => {
      const dx = p.x - g.companion.x, dy = p.y - g.companion.y;
      const dist = Math.sqrt(dx*dx + dy*dy);
      if (dist < 220 && Math.random() < 0.025) {
        const len = dist || 1;
        g.bullets.push({ x: g.companion.x + 30, y: g.companion.y + 10, vx: 6*(dx/len), vy: 6*(dy/len), target: p, fromGun: false });
      }
    });
  }

  // ── Move obstacles ─────────────────────────
  function moveList(list) {
    return list.filter(o => { o.x -= spd; return o.x > -70; });
  }
  g.obstacles    = moveList(g.obstacles);
  g.barrels      = moveList(g.barrels);
  g.pterodactyls = g.pterodactyls.filter(p => { p.x -= spd; p.frame++; return p.x > -70; });
  g.slimes       = g.slimes.filter(s => { s.x -= spd * 1.25; return s.x > -70; });

  // ── Move bullets ───────────────────────────
  g.bullets = g.bullets.filter(b => {
    b.x += b.vx; b.y += b.vy;

    if (b.target) {
      const t = b.target;
      // check if target still exists
      const alive =
        g.obstacles.includes(t) ||
        g.barrels.includes(t) ||
        g.pterodactyls.includes(t);

      if (!alive) return false;

      const bHit = { x: b.x - 6, y: b.y + 6, w: 12, h: 12 };
      const tHit = { x: t.x, y: t.y, w: t.w, h: t.h };
      if (rectsOverlap(bHit, tHit)) {
        explosion(t.x + (t.w||0)/2, t.y - (t.h||0)/2,
          t.type === 'barrel' ? '#8B4513' :
          t.type === 'slime'  ? '#3cb371' :
          t.type === 'pter'   ? '#7B68EE' : '#ff6600');

        g.obstacles    = g.obstacles.filter(o => o !== t);
        g.barrels      = g.barrels.filter(o => o !== t);
        g.pterodactyls = g.pterodactyls.filter(o => o !== t);
        return false;
      }
    }

    return b.x < W + 60 && b.y < H + 60 && b.x > -60 && b.y > -60;
  });

  // ── Particles ─────────────────────────────
  g.particles = g.particles.filter(p => {
    p.x += p.vx; p.y += p.vy; p.vy += 0.12; p.life--;
    return p.life > 0;
  });

  // ── Collision detection ────────────────────
  if (d.invincible === 0) {
    const dr = dinoHitbox(d);

    for (const o of g.obstacles) {
      if (rectsOverlap(dr, o)) {
        if (d.shield > 0) {
          explosion(o.x + o.w/2, o.y - o.h/2, '#88ccff');
          d.shield = 0;
          g.obstacles = g.obstacles.filter(x => x !== o);
          showMile('Khiên chặn đòn!');
        } else {
          gameOver(); return;
        }
      }
    }

    for (const b of g.barrels) {
      if (rectsOverlap(dr, b)) {
        explosion(b.x + b.w/2, b.y - b.h/2, '#8B4513');
        g.barrels = g.barrels.filter(x => x !== b);
        g.speed = Math.max(3, g.speed - 1.5);
        showMile('THÙNG NỔ! Tốc độ giảm!');
      }
    }

    for (const p of g.pterodactyls) {
      const pr = { x: p.x + 4, y: p.y + p.h, w: p.w - 8, h: p.h };
      if (rectsOverlap(dr, pr)) {
        if (d.shield > 0) {
          explosion(p.x + p.w/2, p.y, '#88ccff');
          d.shield = 0;
          g.pterodactyls = g.pterodactyls.filter(x => x !== p);
          showMile('Khiên chặn đòn!');
        } else {
          gameOver(); return;
        }
      }
    }

    for (const s of g.slimes) {
      if (rectsOverlap(dr, { x: s.x, y: s.y, w: s.w, h: s.h })) {
        explosion(s.x + s.w/2, s.y - s.h/2, '#3cb371');
        g.slimes = g.slimes.filter(x => x !== s);
        d.slowEffect = 300; // 5 seconds
        showMile('SLIME! Giảm tốc 20% trong 5 giây!');
      }
    }
  }

  updatePowerupUI();
}

// ── Powerup HUD ────────────────────────────────
function updatePowerupUI() {
  const d = game.dino;
  let html = '';
  if (d.invincible > 0) html += `<div class="pu">★ Bất tử ${Math.ceil(d.invincible/60)}s</div>`;
  if (d.shield     > 0) html += `<div class="pu">▣ Khiên</div>`;
  if (d.slowEffect > 0) html += `<div class="pu">~ Chậm ${Math.ceil(d.slowEffect/60)}s</div>`;
  if (d.gun)            html += `<div class="pu">Z Súng${d.gunCooldown > 0 ? ' '+Math.ceil(d.gunCooldown/60)+'s' : ' sẵn'}</div>`;
  if (game.companion)   html += `<div class="pu">P Đồng hành</div>`;
  if (game.ufo)         html += `<div class="pu">O UFO${game.ufoCooldown > 0 ? ' '+Math.ceil(game.ufoCooldown/60)+'s' : ''}</div>`;
  puEl.innerHTML = html;
}

// ── Draw scene ─────────────────────────────────
function draw() {
  ctx.clearRect(0, 0, W, H);

  // background
  ctx.fillStyle = game.nightMode ? '#1a1a2e' : '#f7f7f0';
  ctx.fillRect(0, 0, W, H);

  drawStars();
  drawClouds();
  drawGround();

  game.obstacles.forEach(drawCactus);
  game.barrels.forEach(drawBarrel);
  game.pterodactyls.forEach(p => drawPterodactyl(p));
  game.slimes.forEach(drawSlime);
  game.particles.forEach(drawParticle);

  if (game.companion) drawCompanion(game.companion);
  if (game.ufo)       drawUFO(game.ufo);

  game.bullets.forEach(drawBullet);
  drawDino(game.dino);
}

// ── Game over ──────────────────────────────────
function gameOver() {
  game.running = false;
  cancelAnimationFrame(animId);

  const taunt = getTaunt();
  tauntEl.textContent = taunt;
  overlay.querySelector('h2').textContent = 'GAME OVER';
  overlay.querySelector('p').textContent  = `Điểm: ${fmt(game.score)}   |   Kỷ lục: ${fmt(hiScore)}`;
  startBtn.textContent = 'CHƠI LẠI';
  overlay.style.display = 'flex';
}

// ── Main loop ──────────────────────────────────
function loop() {
  if (!game.running) return;
  update();
  draw();
  animId = requestAnimationFrame(loop);
}

// ── Start ──────────────────────────────────────
function startGame() {
  overlay.style.display = 'none';
  initGame();
  game.running = true;

  // draw one frame before loop
  draw();
  animId = requestAnimationFrame(loop);
}

startBtn.addEventListener('click', startGame);

// ── Input handling ─────────────────────────────
document.addEventListener('keydown', e => {
  if (!game.running) return;
  const d = game.dino;

  if (e.code === 'Space' || e.code === 'ArrowUp') {
    e.preventDefault();
    if (d.jumpCount < 2) {
      d.vy = d.jumpCount === 0 ? -16 : -13;
      d.jumping   = true;
      d.jumpCount++;
    }
  }

  if (e.code === 'ArrowDown') {
    // duck — clamp y slightly lower (future: ducking sprite)
  }

  // gun shoot
  if (e.code === 'KeyZ' && d.gun && d.gunCooldown === 0) {
    const allT = [...game.obstacles, ...game.barrels, ...game.pterodactyls];
    const target = allT.filter(o => o.x > d.x).sort((a,b) => a.x - b.x)[0];
    if (target) {
      const ty = target.y - (target.h || 0) / 2;
      const dx = target.x - (d.x + d.w + 14);
      const dy = ty - (d.y - d.h + 26);
      const len = Math.sqrt(dx*dx + dy*dy) || 1;
      game.bullets.push({
        x: d.x + d.w + 14, y: d.y - d.h + 26,
        vx: 10 * (dx/len), vy: 10 * (dy/len),
        target, fromGun: true,
      });
      d.gunCooldown = 300; // 5 seconds
    }
  }
});

// Touch / mobile
document.addEventListener('touchstart', e => {
  e.preventDefault();
  if (!game.running) return;
  const d = game.dino;
  if (d.jumpCount < 2) {
    d.vy = d.jumpCount === 0 ? -16 : -13;
    d.jumping   = true;
    d.jumpCount++;
  }
}, { passive: false });

// ── Initial static draw ────────────────────────
(function initialDraw() {
  ctx.fillStyle = '#f7f7f0';
  ctx.fillRect(0, 0, W, H);
  ctx.strokeStyle = '#535353'; ctx.lineWidth = 2;
  ctx.beginPath(); ctx.moveTo(0, GROUND + 2); ctx.lineTo(W, GROUND + 2); ctx.stroke();
  // static dino preview
  const preview = { x: 80, y: GROUND, w: 44, h: 48, invincible: 0, shield: 0, gun: false, jumping: false, legFrame: 0 };
  game.dino = preview; game.frame = 0; game.nightMode = false;
  drawDino(preview);
})();
